# Choose `gemini`, `ollama`, or `openai`.
RAG_LLM_PROVIDER=gemini
RAG_OLLAMA_MODEL=llama3.2
RAG_OPENAI_MODEL=gpt-4o-mini
RAG_GEMINI_MODEL=gemini-3.6-flash

# Add only the key for the provider you plan to use.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Local embedding model downloaded by Sentence Transformers on first indexing.
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Retrieval defaults
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_DENSE_TOP_K=8
RAG_BM25_TOP_K=8
RAG_RERANK_CANDIDATES=10
RAG_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RAG_FINAL_TOP_K=5
